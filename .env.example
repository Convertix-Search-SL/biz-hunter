# Biz Hunter — variables de entorno (copia a .env y rellena).
# El docker-compose pasa .env al contenedor de Hermes y al de LiteLLM.

# === Anthropic (LLM principal) ===
ANTHROPIC_API_KEY=

# === Telegram (notificaciones inmediatas) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# Email digest: deshabilitado. Si lo quieres, ver git history del commit
# inicial — incluye SMTP_* y scripts/send_digest.py para Gmail App Password.

# === Cloudflare Pages (deploy de landings) ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CF_PAGES_PROJECT=biz-hunter-mvps

# === Supabase (waitlist signups en landings) ===
# Free tier: 50k MAU, 500MB DB. Tabla `waitlist_signups` definida en
# README (SQL en sección Setup). Anon key se usa en el HTML de las
# landings (RLS bloquea SELECT, solo INSERT). Service key la usa el
# agente para consultar conteos.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# === Reddit (auth opcional, mejora rate limits) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=biz-hunter/0.1 by david

# === LiteLLM proxy (failover; opcional) ===
OPENROUTER_API_KEY=

# === Hermes UID (alinear permisos volume macOS) ===
HERMES_UID=501
