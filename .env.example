# Biz Hunter — variables de entorno (copia a .env y rellena).
# El docker-compose pasa .env al contenedor de Hermes y al de LiteLLM.

# === Anthropic (LLM principal) ===
ANTHROPIC_API_KEY=

# === Telegram (notificaciones inmediatas) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# Email digest: deshabilitado. Si lo quieres, ver git history del commit
# inicial — incluye SMTP_* y scripts/send_digest.py para Gmail App Password.

# === Cloudflare Pages (deploy de landings) ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CF_PAGES_PROJECT=biz-hunter-mvps

# === n8n webhooks (waitlist signups) ===
# Backend: Postgres VPS, DB `biz_hunter`, tabla `waitlist_signups`.
# Workflows en n8n/workflow-{signup,count}.json. Setup en n8n/SETUP.md.
N8N_WEBHOOK_BASE=https://n8n.convertix.net/webhook
N8N_WEBHOOK_SIGNUP_URL=https://n8n.convertix.net/webhook/biz-hunter/signup
N8N_WEBHOOK_COUNT_URL=https://n8n.convertix.net/webhook/biz-hunter/count

# === Reddit (auth opcional, mejora rate limits) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=biz-hunter/0.1 by david

# === LiteLLM proxy (failover; opcional) ===
OPENROUTER_API_KEY=

# === Hermes UID (alinear permisos volume macOS) ===
HERMES_UID=501

# === Project Builder (V1 funcional) ===
# UID/GID del user del host para chown final tras build (evita root-owned files).
HOST_UID=501
HOST_GID=20
# Cap diario de proyectos auto-generados (manual /build siempre se procesa)
MAX_BUILDS_PER_DAY=8
